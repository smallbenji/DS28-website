services:
  db:
    image: mariadb:10.11
    restart: always
    networks:
      - internal-net
    environment:
      MYSQL_ROOT_PASSWORD: "{{ lookup('ansible.builtin.passwordstore', 'secrets/wp-db-root') }}"
      MYSQL_DATABASE: wordpress
      MYSQL_USER: wordpress
      MYSQL_PASSWORD: "{{ lookup('ansible.builtin.passwordstore', 'secrets/wp-db-user-pass') }}"
    volumes:
      - ./db:/var/lib/mysql

  wordpress:
    depends_on:
      - db
    image: wordpress:latest
    restart: always
    networks:
      - coolify
      - internal-net
    labels:
      - traefik.enable=true
      - traefik.http.middlewares.gzip.compress=true
      - traefik.http.routers.http-ds-wordpress.entryPoints=http
      - traefik.http.routers.http-ds-wordpress.middlewares=redirect-to-https
      - 'traefik.http.routers.http-ds-wordpress.rule=(Host(`distriktssommerlejr.dk`) || Host(`www.distriktssommerlejr.dk`)) && PathPrefix(`/`)'
      - traefik.http.routers.http-ds-wordpress.service=http-ds-wordpress
      - traefik.http.routers.https-ds-wordpress.entryPoints=https
      - traefik.http.routers.https-ds-wordpress.middlewares=gzip
      - 'traefik.http.routers.https-ds-wordpress.rule=(Host(`distriktssommerlejr.dk`) || Host(`www.distriktssommerlejr.dk`)) && PathPrefix(`/`)'
      - traefik.http.routers.https-ds-wordpress.service=https-ds-wordpress
      - traefik.http.routers.https-ds-wordpress.tls.certresolver=letsencrypt
      - traefik.http.routers.https-ds-wordpress.tls=true
      - traefik.http.services.http-ds-wordpress.loadbalancer.server.port=80
      - traefik.http.services.https-ds-wordpress.loadbalancer.server.port=80
    environment:
      WORDPRESS_DB_HOST: db
      WORDPRESS_DB_USER: wordpress
      WORDPRESS_DB_PASSWORD: "{{ lookup('ansible.builtin.passwordstore', 'secrets/wp-db-root' }}"
      WORDPRESS_DB_NAME: wordpress
    volumes:
      - ./wp:/var/www/html
networks:
  coolify:
    external: true
  internal-net:
    driver: bridge